generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  password            String
  role                Role           @default(EMPLOYEE)
  isEmailVerified     Boolean        @default(false)
  emailVerifyToken    String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  refreshToken        String?
  lastLogin           DateTime?
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  auditLogs           AuditLog[]
  employee            Employee?
  notifications       Notification[]
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String     @unique
  description String?
  managerId   String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  manager     Employee?  @relation("DepartmentManager", fields: [managerId], references: [id])
  employees   Employee[]
}

model Skill {
  id        String          @id @default(uuid())
  name      String          @unique
  category  String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  employees EmployeeSkill[]
}

model Employee {
  id                String             @id @default(uuid())
  employeeId        String             @unique
  userId            String             @unique
  firstName         String
  lastName          String
  email             String             @unique
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  country           String             @default("India")
  pincode           String?
  departmentId      String?
  designation       String?
  joiningDate       DateTime?
  salary            Decimal?           @db.Decimal(12, 2)
  managerId         String?
  profileImage      String?
  resumeUrl         String?
  documents         Json?
  emergencyContact  Json?
  bankDetails       Json?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  allocatedAssets   AssetAllocation[]
  managedDepts      Department[]       @relation("DepartmentManager")
  department        Department?        @relation(fields: [departmentId], references: [id])
  manager           Employee?          @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates      Employee[]         @relation("EmployeeManager")
  user              User               @relation(fields: [userId], references: [id])
  skills            EmployeeSkill[]
  leaveApplications LeaveApplication[]
  hrProcessedLeaves LeaveApplication[] @relation("LeaveHR")
  managedLeaves     LeaveApplication[] @relation("LeaveManager")
  leaveBalances     LeaveBalance[]
}

model EmployeeSkill {
  id         String   @id @default(uuid())
  employeeId String
  skillId    String
  level      String
  yearsExp   Int?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  skill      Skill    @relation(fields: [skillId], references: [id])

  @@unique([employeeId, skillId])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  leaveType   LeaveType
  year        Int
  totalDays   Int       @default(0)
  usedDays    Int       @default(0)
  pendingDays Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveType, year])
}

model LeaveApplication {
  id              String      @id @default(uuid())
  employeeId      String
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  reason          String
  status          LeaveStatus @default(PENDING)
  managerId       String?
  managerComment  String?
  managerActionAt DateTime?
  hrId            String?
  hrComment       String?
  hrActionAt      DateTime?
  attachmentUrl   String?
  isHalfDay       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])
  hrProcessor     Employee?   @relation("LeaveHR", fields: [hrId], references: [id])
  manager         Employee?   @relation("LeaveManager", fields: [managerId], references: [id])
}

model Asset {
  id             String            @id @default(uuid())
  assetTag       String            @unique
  name           String
  assetType      AssetType
  brand          String?
  model          String?
  serialNumber   String?           @unique
  purchaseDate   DateTime?
  purchaseCost   Decimal?          @db.Decimal(12, 2)
  warrantyExpiry DateTime?
  status         AssetStatus       @default(AVAILABLE)
  condition      String?
  specifications Json?
  location       String?
  notes          String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  allocations    AssetAllocation[]
}

model AssetAllocation {
  id          String    @id @default(uuid())
  assetId     String
  employeeId  String
  allocatedAt DateTime  @default(now())
  returnedAt  DateTime?
  allocatedBy String?
  returnedTo  String?
  condition   String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  asset       Asset     @relation(fields: [assetId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  MANAGER_APPROVED
  MANAGER_REJECTED
  HR_APPROVED
  HR_REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  MATERNITY
  PATERNITY
  UNPAID
  COMPENSATORY
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  UNDER_MAINTENANCE
  RETIRED
}

enum AssetType {
  LAPTOP
  MONITOR
  KEYBOARD
  MOUSE
  HEADSET
  PHONE
  ID_CARD
  ACCESS_CARD
  OTHER
}

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  ASSET_ASSIGNED
  ASSET_RETURNED
  PROFILE_UPDATED
  SYSTEM
}
